page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1f2a37;
  background-color: #f4f2ec;
  box-sizing: border-box;
}

view, text, image, button, input, textarea {
  box-sizing: border-box;
}

image {
  display: block;
}

.btn {
  border: 2rpx solid #d8deea;
  border-radius: 28rpx;
  background-color: #fff;
  color: #39465b;
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn.primary {
  color: #fff;
  border-color: #1e5ea6;
  background: linear-gradient(135deg, #2b72bc 0%, #1e5ea6 100%);
}
