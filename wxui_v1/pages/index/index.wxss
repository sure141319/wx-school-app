.home-page {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding: 28rpx;
  padding-bottom: 120rpx;
}

.home-hero {
  padding: 28rpx;
  background: linear-gradient(150deg, #fff7e6 0%, #f8f3ea 45%, #edf5ff 100%);
}

.hero-top {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-actions {
  display: flex;
  gap: 12rpx;
}

.icon-btn {
  border: 2rpx solid #d2dbe9;
  width: 76rpx;
  height: 76rpx;
  border-radius: 26rpx;
  background-color: rgba(255, 255, 255, 0.94);
  color: #253247;
  display: flex;
  align-items: center;
  justify-content: center;
}

.refresh-icon {
  font-size: 36rpx;
  line-height: 1;
}

.hero-title {
  margin: 28rpx 0 8rpx;
  font-size: 48rpx;
  letter-spacing: 0.01em;
  display: block;
}

.hero-sub {
  font-size: 26rpx;
  color: #768195;
  display: block;
}

.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  border: 2rpx solid #dde4ef;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 0 24rpx;
  height: 84rpx;
}

.search-icon {
  color: #8894a6;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input input {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

.category-strip {
  display: flex;
  white-space: nowrap;
}

.category-pill {
  display: inline-flex;
  align-items: center;
  border: 2rpx solid #dde4ef;
  border-radius: 999rpx;
  height: 68rpx;
  padding: 0 28rpx;
  background-color: rgba(255, 255, 255, 0.8);
  color: #5e6d83;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.category-pill.active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
  font-weight: 600;
}

.status-line {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.7);
  color: #6c788b;
  font-size: 26rpx;
  display: block;
}

.loading {
  padding: 40rpx;
  text-align: center;
  color: #6b7a8d;
}

.loading-more {
  padding: 32rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.waterfall {
  display: flex;
  gap: 24rpx;
}

.waterfall-col {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-card {
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background-color: #fff;
  border: 2rpx solid #ece7de;
  box-shadow: 0 16rpx 32rpx rgba(26, 34, 51, 0.06);
}

.cover {
  position: relative;
  background-color: #f0f3f8;
  height: 300rpx;
}

.cover image {
  width: 100%;
  height: 100%;
}

.cover-empty {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8c97aa;
  font-size: 26rpx;
}

.price-tag {
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
  background-color: rgba(255, 255, 255, 0.96);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2a37;
}

.cond-tag {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  background-color: rgba(30, 94, 166, 0.86);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.meta {
  padding: 20rpx 20rpx 24rpx;
}

.title {
  font-size: 28rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.location {
  margin-top: 8rpx;
  color: #7d889a;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.empty-state {
  padding: 40rpx 28rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-desc {
  color: #7f8b9f;
  font-size: 26rpx;
  display: block;
}

.paper {
  background-color: #ffffff;
  border: 2rpx solid #ece7de;
  border-radius: 40rpx;
  box-shadow: 0 16rpx 36rpx rgba(26, 31, 45, 0.04);
}
