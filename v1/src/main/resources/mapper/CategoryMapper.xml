<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campustrade.platform.category.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.campustrade.platform.category.dataobject.CategoryDO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="enabled" column="enabled"/>
    </resultMap>

    <select id="countAll" resultType="long">
        SELECT COUNT(1) FROM category_do
    </select>

    <insert id="insert" parameterType="com.campustrade.platform.category.dataobject.CategoryDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category_do (name, sort_order, enabled)
        VALUES (#{name}, #{sortOrder}, #{enabled})
    </insert>

    <select id="findById" resultMap="CategoryResultMap">
        SELECT id, name, sort_order, enabled
        FROM category_do
        WHERE id = #{id}
    </select>

    <select id="findEnabledTrueOrderBySortOrderAscNameAsc" resultMap="CategoryResultMap">
        SELECT id, name, sort_order, enabled
        FROM category_do
        WHERE enabled = TRUE
        ORDER BY sort_order ASC, name ASC
    </select>

</mapper>
