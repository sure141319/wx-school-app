<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campustrade.platform.announcement.mapper.AnnouncementMapper">

    <resultMap id="AnnouncementMap" type="com.campustrade.platform.announcement.dataobject.AnnouncementDO">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="enabled" column="enabled"/>
        <result property="revision" column="revision"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findCurrent" resultMap="AnnouncementMap">
        SELECT id, title, content, enabled, revision, created_at, updated_at
        FROM announcement_config
        WHERE id = 1
    </select>

    <update id="updateCurrent">
        UPDATE announcement_config
        SET title = #{title},
            content = #{content},
            enabled = #{enabled},
            revision = revision + 1,
            updated_at = CURRENT_TIMESTAMP
        WHERE id = 1
    </update>

</mapper>
