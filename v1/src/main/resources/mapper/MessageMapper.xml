<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campustrade.platform.message.mapper.MessageMapper">

    <resultMap id="MessageDetailMap" type="com.campustrade.platform.message.dataobject.MessageDO">
        <id property="id" column="message_id"/>
        <result property="conversationId" column="conversation_id"/>
        <result property="senderId" column="sender_id_raw"/>
        <result property="content" column="message_content"/>
        <result property="createdAt" column="message_created_at"/>

        <association property="conversation" javaType="com.campustrade.platform.message.dataobject.ConversationDO">
            <id property="id" column="conversation_id"/>
        </association>

        <association property="sender" javaType="com.campustrade.platform.user.dataobject.UserDO">
            <id property="id" column="sender_id"/>
            <result property="email" column="sender_email"/>
            <result property="nickname" column="sender_nickname"/>
            <result property="avatarUrl" column="sender_avatar_url"/>
        </association>
    </resultMap>

    <sql id="MessageColumns">
        m.id AS message_id,
        m.conversation_id AS conversation_id,
        m.sender_id AS sender_id_raw,
        m.content AS message_content,
        m.created_at AS message_created_at,

        s.id AS sender_id,
        s.email AS sender_email,
        s.nickname AS sender_nickname,
        s.avatar_url AS sender_avatar_url
    </sql>

    <insert id="insert" parameterType="com.campustrade.platform.message.dataobject.MessageDO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO messages (conversation_id, sender_id, content, created_at)
        VALUES (#{conversationId}, #{senderId}, #{content}, NOW())
    </insert>

    <select id="findById" resultMap="MessageDetailMap">
        SELECT
        <include refid="MessageColumns"/>
        FROM messages m
        JOIN users s ON s.id = m.sender_id
        WHERE m.id = #{id}
    </select>

    <select id="listByConversationId" resultMap="MessageDetailMap">
        SELECT
        <include refid="MessageColumns"/>
        FROM messages m
        JOIN users s ON s.id = m.sender_id
        WHERE m.conversation_id = #{conversationId}
        ORDER BY m.created_at ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByConversationId" resultType="long">
        SELECT COUNT(1)
        FROM messages
        WHERE conversation_id = #{conversationId}
    </select>

</mapper>
