/* ===== Base Reset ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1f2a37;
  background-color: #f4f2ec;
  box-sizing: border-box;
}

view, text, image, button, input, textarea {
  box-sizing: border-box;
}

image { display: block; }

/* ===== Layout ===== */
.flex { display: flex; }
.inline-flex { display: inline-flex; }
.block { display: block; }
.inline { display: inline; }
.hidden { display: none; }

.flex-col { flex-direction: column; }
.flex-row { flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-shrink-0 { flex-shrink: 0; }
.flex-none { flex: none; }

.items-center { align-items: center; }
.items-start { align-items: flex-start; }
.items-baseline { align-items: baseline; }
.items-end { align-items: flex-end; }

.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }
.justify-end { justify-content: flex-end; }

/* ===== Spacing (rpx scale) ===== */
.gap-4 { gap: 4rpx; }    .gap-6 { gap: 6rpx; }
.gap-8 { gap: 8rpx; }    .gap-12 { gap: 12rpx; }
.gap-16 { gap: 16rpx; }  .gap-20 { gap: 20rpx; }
.gap-24 { gap: 24rpx; }  .gap-28 { gap: 28rpx; }
.gap-32 { gap: 32rpx; }

.p-0 { padding: 0; }
.p-4 { padding: 4rpx; }    .p-8 { padding: 8rpx; }
.p-12 { padding: 12rpx; }  .p-16 { padding: 16rpx; }
.p-20 { padding: 20rpx; }  .p-24 { padding: 24rpx; }
.p-28 { padding: 28rpx; }  .p-32 { padding: 32rpx; }
.p-40 { padding: 40rpx; }  .p-60 { padding: 60rpx; }

.px-4 { padding-left: 4rpx; padding-right: 4rpx; }
.px-16 { padding-left: 16rpx; padding-right: 16rpx; }
.px-20 { padding-left: 20rpx; padding-right: 20rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.px-28 { padding-left: 28rpx; padding-right: 28rpx; }
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }
.px-40 { padding-left: 40rpx; padding-right: 40rpx; }

.py-0 { padding-top: 0; padding-bottom: 0; }
.py-4 { padding-top: 4rpx; padding-bottom: 4rpx; }
.py-8 { padding-top: 8rpx; padding-bottom: 8rpx; }
.py-12 { padding-top: 12rpx; padding-bottom: 12rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-20 { padding-top: 20rpx; padding-bottom: 20rpx; }
.py-24 { padding-top: 24rpx; padding-bottom: 24rpx; }
.py-28 { padding-top: 28rpx; padding-bottom: 28rpx; }

.pt-0 { padding-top: 0; }   .pt-8 { padding-top: 8rpx; }
.pt-16 { padding-top: 16rpx; }  .pt-20 { padding-top: 20rpx; }
.pt-24 { padding-top: 24rpx; }  .pt-28 { padding-top: 28rpx; }

.pb-4 { padding-bottom: 4rpx; }   .pb-16 { padding-bottom: 16rpx; }
.pb-20 { padding-bottom: 20rpx; } .pb-24 { padding-bottom: 24rpx; }
.pb-28 { padding-bottom: 28rpx; } .pb-32 { padding-bottom: 32rpx; }
.pb-120 { padding-bottom: 120rpx; }

.pl-24 { padding-left: 24rpx; } .pr-24 { padding-right: 24rpx; }

.m-0 { margin: 0; }
.mt-4 { margin-top: 4rpx; }   .mt-8 { margin-top: 8rpx; }
.mt-12 { margin-top: 12rpx; } .mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; } .mt-24 { margin-top: 24rpx; }
.mt-28 { margin-top: 28rpx; } .mt-48 { margin-top: 48rpx; }
.mt-52 { margin-top: 52rpx; } .mt-84 { margin-top: 84rpx; }

.mb-6 { margin-bottom: 6rpx; }   .mb-8 { margin-bottom: 8rpx; }
.mb-12 { margin-bottom: 12rpx; } .mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; } .mb-24 { margin-bottom: 24rpx; }
.mb-28 { margin-bottom: 28rpx; }

.mr-4 { margin-right: 4rpx; } .mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }

.ml-4 { margin-left: 4rpx; }  .ml-16 { margin-left: 16rpx; }
.ml-auto { margin-left: auto; }

/* ===== Sizing ===== */
.w-full { width: 100%; }
.w-auto { width: auto; }
.h-full { height: 100%; }
.min-h-screen { min-height: 100vh; }
.min-w-0 { min-width: 0; }
.max-w-560 { max-width: 560rpx; }

/* ===== Typography ===== */
.text-hero { font-size: 72rpx; }   .text-4xl { font-size: 56rpx; }
.text-3xl { font-size: 48rpx; }    .text-2xl { font-size: 44rpx; }
.text-xl { font-size: 36rpx; }     .text-lg { font-size: 34rpx; }
.text-base { font-size: 30rpx; }   .text-sm { font-size: 28rpx; }
.text-xs { font-size: 26rpx; }     .text-2xs { font-size: 24rpx; }
.text-tiny { font-size: 22rpx; }   .text-price { font-size: 44rpx; }

.font-bold { font-weight: 700; }
.font-semibold { font-weight: 600; }
.font-medium { font-weight: 500; }
.font-normal { font-weight: 400; }

.text-center { text-align: center; }
.text-left { text-align: left; }

.leading-tight { line-height: 1.08; }
.leading-snug { line-height: 1.35; }
.leading-normal { line-height: 1.5; }
.leading-relaxed { line-height: 1.7; }

.truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.whitespace-nowrap { white-space: nowrap; }
.whitespace-pre-wrap { white-space: pre-wrap; }
.break-word { word-break: break-word; }
.tracking-tight { letter-spacing: -1rpx; }

/* ===== Colors - Text ===== */
.text-white { color: #fff; }
.text-black { color: #000; }
.text-main { color: #1f2a37; }
.text-secondary { color: #768195; }
.text-muted { color: #9ca3af; }
.text-label { color: #687488; }
.text-primary { color: #2b72bc; }
.text-primary-dark { color: #1e5ea6; }
.text-danger { color: #f25b57; }
.text-warning { color: #d48806; }
.text-success { color: #52c41a; }
.text-acc-hero { color: #73839c; }
.text-acc-sub { color: #7d899b; }
.text-price-red { color: #e8433a; }
.text-card-title { color: #1a1f2d; }
.text-card-body { color: #4a5060; }
.text-btn-outline { color: #39465b; }

/* ===== Colors - Background ===== */
.bg-white { background-color: #fff; }
.bg-transparent { background-color: transparent; }
.bg-page { background-color: #f4f2ec; }
.bg-card { background-color: #ffffff; }
.bg-input { background-color: #fff; }
.bg-overlay { background-color: rgba(0,0,0,0.45); }
.bg-overlay-light { background-color: rgba(255,255,255,0.9); }
.bg-primary { background-color: #1e5ea6; }
.bg-primary-light { background-color: #e8f4fd; }
.bg-danger-light { background-color: #fff1f0; }
.bg-warning-light { background-color: #fff7e6; }
.bg-success-light { background-color: #e6f7e6; }
.bg-gray-light { background-color: #f0f0f0; }
.bg-avatar { background: linear-gradient(135deg, #2b72bc, #1e5ea6); }
.bg-avatar-accent { background: linear-gradient(145deg, #7dcba0, #6ebf94); }
.bg-price-tag { background-color: rgba(255,255,255,0.96); }
.bg-btn-primary { background: linear-gradient(135deg, #2b72bc 0%, #1e5ea6 100%); }
.bg-btn-disabled { background: #9db9dc; }
.bg-publish { background-color: #f5f5f5; }

/* ===== Borders ===== */
.border { border: 2rpx solid #dde4ef; }
.border-2 { border-width: 2rpx; }
.border-solid { border-style: solid; }
.border-dashed { border-style: dashed; }
.border-none { border: none; }
.border-t { border-top: 2rpx solid #f0f0f0; }
.border-b { border-bottom: 2rpx solid #f0f0f0; }
.border-r { border-right: 2rpx solid #dedbe5; }

.border-card { border-color: #ece7de; }
.border-input { border-color: #dfe5ee; }
.border-primary { border-color: #1e5ea6; }
.border-primary-light { border-color: #2b72bc; }
.border-danger { border-color: #f5d5d5; }
.border-muted { border-color: #e5e7eb; }
.border-pill { border-color: #dde4ef; }
.border-container { border-color: #d8e1ee; }
.border-divider { border-color: #f0f2f5; }
.border-dropdown { border-color: #c5cdd8; }

.rounded-sm { border-radius: 8rpx; }
.rounded { border-radius: 12rpx; }
.rounded-md { border-radius: 16rpx; }
.rounded-lg { border-radius: 20rpx; }
.rounded-xl { border-radius: 24rpx; }
.rounded-2xl { border-radius: 28rpx; }
.rounded-3xl { border-radius: 32rpx; }
.rounded-4xl { border-radius: 40rpx; }
.rounded-full { border-radius: 999rpx; }

/* ===== Shadow ===== */
.shadow-card { box-shadow: 0 16rpx 36rpx rgba(26,31,45,0.04); }
.shadow-md { box-shadow: 0 16rpx 32rpx rgba(26,34,51,0.06); }
.shadow-lg { box-shadow: 0 20rpx 48rpx rgba(32,40,57,0.06); }
.shadow-dropdown { box-shadow: 0 24rpx 80rpx rgba(32,40,57,0.22); }

/* ===== Position ===== */
.relative { position: relative; }
.absolute { position: absolute; }
.fixed { position: fixed; }
.sticky { position: sticky; }

.inset-0 { top: 0; left: 0; right: 0; bottom: 0; }
.top-0 { top: 0; }
.top-50 { top: 50%; }
.top-20 { top: 20rpx; }
.left-0 { left: 0; }
.left-20 { left: 20rpx; }
.left-50 { left: 50%; }
.left-40 { left: 40rpx; }
.right-0 { right: 0; }
.right-20 { right: 20rpx; }
.right-28 { right: 28rpx; }
.bottom-0 { bottom: 0; }
.bottom-20 { bottom: 20rpx; }
.bottom-24 { bottom: 24rpx; }

.z-0 { z-index: 0; }
.z-10 { z-index: 10; }
.z-20 { z-index: 20; }
.z-100 { z-index: 100; }
.z-101 { z-index: 101; }
.z-n1 { z-index: -1; }

/* ===== Overflow ===== */
.overflow-hidden { overflow: hidden; }
.overflow-y-auto { overflow-y: auto; }
.overflow-x-auto { overflow-x: auto; }

/* ===== Effects ===== */
.opacity-50 { opacity: 0.5; }

/* ===== Sizing (fixed dimensions) ===== */
.w-40 { width: 40rpx; }  .h-40 { height: 40rpx; }
.w-56 { width: 56rpx; }  .h-56 { height: 56rpx; }
.w-68 { width: 68rpx; }  .h-68 { height: 68rpx; }
.w-76 { width: 76rpx; }  .h-76 { height: 76rpx; }
.w-80 { width: 80rpx; }  .h-80 { height: 80rpx; }
.w-84 { width: 84rpx; }  .h-84 { height: 84rpx; }
.w-88 { width: 88rpx; }  .h-88 { height: 88rpx; }
.w-92 { width: 92rpx; }  .h-92 { height: 92rpx; }
.w-96 { width: 96rpx; }  .h-96 { height: 96rpx; }
.w-120 { width: 120rpx; } .h-120 { height: 120rpx; }
.w-180 { width: 180rpx; } .h-180 { height: 180rpx; }

/* ===== Width percentages ===== */
.w-33p { width: 33.33%; }
.w-78 { width: 78%; }

/* ===== Specific heights ===== */
.h-60 { height: 60rpx; }
.h-300 { height: 300rpx; }
.h-440 { height: 440rpx; }
.h-750 { height: 750rpx; }

/* ===== Section titles ===== */
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.2;
}

/* ===== Buttons (global) ===== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #d8deea;
  border-radius: 28rpx;
  background-color: #fff;
  color: #39465b;
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  text-align: center;
  margin: 0;
}

.btn[disabled] { opacity: 0.5; }

.btn-primary {
  color: #fff;
  border-color: #1e5ea6;
  background: linear-gradient(135deg, #2b72bc 0%, #1e5ea6 100%);
}

.btn-primary[disabled] {
  background: #9db9dc;
  border-color: #9db9dc;
}

.btn-primary:not([disabled]):active {
  background: linear-gradient(135deg, #1e5ea6 0%, #1a4d8a 100%);
}

.btn-full { width: 100%; height: 92rpx; font-size: 30rpx; margin-top: 8rpx; }

.btn-sm {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  flex: none;
}

.btn-danger {
  color: #f25b57;
  border-color: #f5d5d5;
}

.btn-logout {
  margin-top: 16rpx;
  color: #9ca3af;
  border-color: #e5e7eb;
  background-color: #f9fafb;
  font-size: 28rpx;
}

.btn-copy {
  font-size: 24rpx;
  color: #2b72bc;
  border: 2rpx solid #2b72bc;
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
  background: rgba(43, 114, 188, 0.08);
}

.btn-copy::after { border: none; }

.btn-publish {
  width: 100%;
  height: 96rpx;
  border: none;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #2b72bc, #1e5ea6);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-publish[disabled] { background: #ccc; }

.btn-back-home {
  margin-top: 20rpx;
  padding: 16rpx 48rpx;
  border-radius: 999rpx;
  background-color: #1e5ea6;
  color: #fff;
  font-size: 28rpx;
  border: none;
}

.btn-back-home::after { border: none; }

.btn-modal {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #2b72bc 0%, #1e5ea6 100%);
  color: #fff;
  font-size: 30rpx;
  border-radius: 24rpx;
  border: none;
  text-align: center;
  margin: 0;
  padding: 0;
}

/* ===== Status Tags ===== */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-ON_SALE { background-color: #e6f7e6; color: #52c41a; }
.status-OFF_SHELF { background-color: #f0f0f0; color: #8c8c8c; }
.status-PENDING_REVIEW { background-color: #fff7e6; color: #fa8c16; }
.status-REJECTED { background-color: #fff1f0; color: #f5222d; }

/* ===== Condition / Category Tags ===== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.tag-cond { background-color: #fff3e6; color: #d48806; }
.tag-loc { background-color: #e8f4fd; color: #1e5ea6; }
.tag-cat { background-color: #f0edf8; color: #6b52a8; }

/* ===== Cards ===== */
.card {
  background-color: #ffffff;
  border: 2rpx solid #ece7de;
  border-radius: 40rpx;
  box-shadow: 0 16rpx 36rpx rgba(26,31,45,0.04);
}

.card-section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

/* ===== Form elements ===== */
.input-field {
  box-sizing: border-box;
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #dfe5ee;
  background-color: #fff;
  padding: 0 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #253247;
}

.input-field-nick {
  height: 80rpx;
  border: 2rpx solid #dfe5ee;
  border-radius: 20rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.input-field-price {
  flex: 1;
  border: none;
  font-size: 44rpx;
  font-weight: 700;
  color: #e8433a;
  padding: 0;
  background: transparent;
  height: 80rpx;
  line-height: 80rpx;
  min-height: 80rpx;
}

.input-field-text {
  flex: 1;
  border: none;
  font-size: 30rpx;
  padding: 0;
  background: transparent;
  height: 60rpx;
  line-height: 60rpx;
  min-height: 60rpx;
}

.form-label {
  font-size: 26rpx;
  color: #687488;
  margin-bottom: 12rpx;
  display: block;
}

.field-error {
  display: block;
  color: #f25b57;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.field-hint {
  display: block;
  color: #6d7f97;
  font-size: 24rpx;
  margin-top: 8rpx;
}

/* ===== Search ===== */
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  border: 2rpx solid #dde4ef;
  border-radius: 24rpx;
  background-color: rgba(255,255,255,0.9);
  padding: 0 24rpx;
  height: 84rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

/* ===== Category Pills ===== */
.cat-pill {
  display: inline-flex;
  align-items: center;
  border: 2rpx solid #dde4ef;
  border-radius: 999rpx;
  height: 68rpx;
  padding: 0 28rpx;
  background-color: rgba(255,255,255,0.8);
  color: #5e6d83;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.cat-pill-active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
  font-weight: 600;
}

/* ===== Goods Card ===== */
.goods-card {
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background-color: #fff;
  border: 2rpx solid #ece7de;
  box-shadow: 0 16rpx 32rpx rgba(26,34,51,0.06);
}

/* ===== Cover ===== */
.cover-wrap {
  position: relative;
  background-color: #f0f3f8;
  height: 300rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-empty {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8c97aa;
  font-size: 26rpx;
}

/* ===== Price / Cond tags on cover ===== */
.price-tag {
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
  background-color: rgba(255,255,255,0.96);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2a37;
}

.cond-tag {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  background-color: rgba(30,94,166,0.86);
  color: #fff;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

/* ===== Card meta ===== */
.card-meta {
  padding: 20rpx 20rpx 24rpx;
}

.card-title {
  font-size: 28rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.card-sub {
  margin-top: 8rpx;
  color: #7d889a;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* ===== Icon Buttons ===== */
.icon-btn {
  border: 2rpx solid #d2dbe9;
  width: 76rpx;
  height: 76rpx;
  border-radius: 26rpx;
  background-color: rgba(255,255,255,0.94);
  color: #253247;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ===== Section Label ===== */
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1f2d;
  display: block;
  margin-bottom: 20rpx;
}

.section-body {
  font-size: 28rpx;
  color: #4a5060;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-word;
  display: block;
}

/* ===== Seller ===== */
.seller-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2b72bc, #1e5ea6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.seller-avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
}

.seller-avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: 600;
}

/* ===== Loading ===== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 200rpx 0;
  color: #8c97aa;
  font-size: 28rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #e8ecf1;
  border-top-color: #1e5ea6;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  padding: 40rpx;
  text-align: center;
  color: #6b7a8d;
}

.loading-more {
  padding: 32rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}

/* ===== Status / Info Text ===== */
.status-text {
  margin: 28rpx 0 0;
  min-height: 40rpx;
  text-align: center;
  color: #667791;
  font-size: 26rpx;
  display: block;
}

.status-text-error {
  color: #f25b57;
}

.status-line {
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  background-color: rgba(255,255,255,0.7);
  color: #6c788b;
  font-size: 26rpx;
  display: block;
}

/* ===== Empty State ===== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
  gap: 24rpx;
}

.empty-list {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  gap: 16rpx;
}

.empty-icon {
  font-size: 120rpx;
}

.empty-icon-sm { font-size: 80rpx; }

.empty-title {
  font-size: 32rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #8c97aa;
}

.empty-desc {
  color: #7f8b9f;
  font-size: 26rpx;
  display: block;
}

.empty-btn {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* ===== Feedback Modal ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  z-index: 100;
}

.modal-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 78%;
  max-width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  padding: 40rpx 40rpx 20rpx;
  color: #1a1a1a;
}

.modal-body {
  padding: 12rpx 40rpx 32rpx;
}

.modal-text {
  display: block;
  font-size: 30rpx;
  color: #4a4a4a;
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.modal-qq-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 8rpx 0 20rpx;
}

.modal-qq-number {
  font-size: 32rpx;
  color: #2b72bc;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.modal-footer {
  border-top: 2rpx solid #f0f0f0;
  padding: 24rpx 40rpx 40rpx;
}

/* ===== Auth specific ===== */
.auth-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(560rpx 440rpx at 85% -80rpx, rgba(43,114,188,0.2), transparent 70%),
    radial-gradient(600rpx 440rpx at -80rpx 260rpx, rgba(255,180,113,0.26), transparent 72%),
    linear-gradient(180deg, #f5f8fc 0%, #f9f4ea 100%);
  z-index: -1;
}

.auth-head-btn {
  border: 2rpx solid #d8e1ee;
  background-color: rgba(255,255,255,0.86);
  color: #4c5a71;
  border-radius: 24rpx;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
}

.auth-form {
  margin-top: 52rpx;
  padding: 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e4ebf4;
  background-color: rgba(255,255,255,0.9);
  box-shadow: 0 20rpx 48rpx rgba(32,40,57,0.06);
}

.form-row {
  margin-bottom: 28rpx;
}

.inline-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.inline-row input { flex: 1; min-width: 0; }

.send-code-btn {
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 88rpx;
  font-size: 26rpx;
  flex-shrink: 0;
  background-color: #fff;
  border: 2rpx solid #d8deea;
  color: #39465b;
  line-height: 88rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
}

.text-link {
  margin-top: 16rpx;
  color: #6d7f97;
  font-size: 26rpx;
  text-align: center;
  display: block;
}

/* ===== Email history dropdown ===== */
.email-history {
  position: absolute;
  top: calc(100% + 12rpx);
  left: 0;
  right: 0;
  background: #fff;
  border: 2rpx solid #c5cdd8;
  border-radius: 16rpx;
  box-shadow: 0 24rpx 80rpx rgba(32,40,57,0.22);
  z-index: 100;
  max-height: 440rpx;
  overflow-y: auto;
}

.email-history::before {
  content: '';
  position: absolute;
  top: -16rpx;
  left: 40rpx;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 16rpx solid #c5cdd8;
}

.email-history::after {
  content: '';
  position: absolute;
  top: -14rpx;
  left: 40rpx;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 16rpx solid #fff;
}

.email-history-header {
  padding: 16rpx 24rpx;
  background: #f7f9fc;
  border-bottom: 2rpx solid #e8ecf2;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.email-history-item {
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.email-history-item:last-child { border-bottom: none; }
.email-history-item:active { background-color: #f0f4f9; }

/* ===== Publish Form ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: calc(33.33% - 12rpx);
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-item::before {
  content: '';
  display: block;
  padding-bottom: 100%;
}

.photo-item image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.photo-add {
  position: relative;
  width: calc(33.33% - 12rpx);
  border: 4rpx dashed #ddd;
  border-radius: 16rpx;
  background-color: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add::before {
  content: '';
  display: block;
  padding-bottom: 100%;
}

.del-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.cover-label {
  position: absolute;
  bottom: 0;
  left: 0;
  background-color: #ff6b3d;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 12rpx 0 0;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 0;
}

.picker-item {
  padding: 20rpx 16rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  background-color: #fff;
  font-size: 26rpx;
  color: #666;
  width: calc(33.33% - 12rpx);
  text-align: center;
}

.picker-item-active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
}

.chip {
  padding: 16rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 40rpx;
  background-color: #fff;
  font-size: 26rpx;
  color: #666;
}

.chip-active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.char-count-full {
  color: #ff4444;
  font-weight: 600;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255,255,255,0.95);
  border-top: 2rpx solid #f0f0f0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
}

/* ===== Profile specific ===== */
.profile-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
}

.avatar-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #7dcba0, #6ebf94);
  color: #fff;
  font-size: 72rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-btn image { width: 100%; height: 100%; }

.nick-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.chip-count {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  border: 2rpx solid #ece7de;
  background-color: #fff;
  padding: 8rpx 22rpx;
  font-size: 24rpx;
  color: #6b7a8d;
}

.goods-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 2rpx dashed #dedbe5;
  padding: 20rpx 0;
}

.goods-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.goods-title-sm {
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.reject-reason {
  font-size: 22rpx;
  color: #f5222d;
  margin-top: 4rpx;
}

.actions-row {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.settings-card {
  padding: 0;
  overflow: hidden;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
}

.settings-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.settings-arrow {
  font-size: 36rpx;
  color: #c0c4cc;
}

/* ===== Image Counter ===== */
.img-counter {
  position: absolute;
  bottom: 24rpx;
  right: 28rpx;
  background-color: rgba(0,0,0,0.4);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

/* ===== Seller QQ Row ===== */
.seller-qq-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e8ecf1;
  gap: 12rpx;
}

/* ===== Notice Box ===== */
.notice-box {
  background: #fff7e6;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #d48806;
  margin-bottom: 10rpx;
}

.notice-item {
  display: block;
  font-size: 26rpx;
  color: #ad6800;
  line-height: 1.6;
}

/* ===== Misc ===== */
.hero-subtitle {
  color: #73839c;
  font-size: 24rpx;
  letter-spacing: 0.06em;
  display: block;
}

.hero-tip {
  color: #7d899b;
  font-size: 26rpx;
  display: block;
}

.bg-card-light { background-color: rgba(255,255,255,0.9); }
.bg-pill { background-color: rgba(255,255,255,0.8); }
.text-pill { color: #5e6d83; }
.text-subtitle { color: #4c5f79; }
