{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "lib": ["ES2020"],
    "types": ["wechat-miniprogram"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "checkJs": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
