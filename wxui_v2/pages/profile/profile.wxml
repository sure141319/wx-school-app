<view class="page-shell flex flex-col gap-24">
  <view class="card p-28 profile-summary-card">
    <view class="profile-summary" bindtap="openProfileEditor">
      <view class="avatar-btn profile-summary-avatar">
        <image wx:if="{{displayAvatarUrl}}" src="{{displayAvatarUrl}}" mode="aspectFill" />
        <text wx:else>{{profile.nickname[0] || '我'}}</text>
      </view>
      <view class="profile-summary-main">
        <text class="profile-summary-name">{{profile.nickname || '微信用户'}}</text>
        <text class="helper-text">点击此处编辑资料与联系方式</text>
        <view class="profile-contact-row">
          <text wx:if="{{profile.wechatId}}" class="profile-contact-tag">微信已填</text>
          <text wx:if="{{profile.qq}}" class="profile-contact-tag">QQ已填</text>
          <text wx:if="{{!profile.wechatId && !profile.qq}}" class="profile-contact-empty">未填写联系方式</text>
        </view>
      </view>
      <text class="settings-arrow">›</text>
    </view>
  </view>

  <text wx:if="{{info && !showProfileModal}}" class="block text-center text-2xs status-text-error">{{info}}</text>

  <view class="card p-28">
    <view class="card-head">
      <view>
        <text class="section-title">我发布的商品</text>
        <text class="helper-text mt-8">管理上下架、编辑和删除</text>
      </view>
      <view class="chip-count">
        <text>{{goodsItems.length}} 件</text>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading-text">
      <text>加载中...</text>
    </view>

    <view wx:elif="{{!goodsItems.length}}" class="empty-list">
      <view class="empty-icon-sm">+</view>
      <text class="empty-title">还没有发布商品</text>
      <text class="empty-desc">把闲置书本、数码配件或生活用品发布给同校同学。</text>
      <navigator url="/pages/publish/publish" open-type="switchTab" class="btn btn-primary btn-sm mt-16">去发布</navigator>
    </view>

    <block wx:for="{{goodsItems}}" wx:key="id">
      <view class="goods-line">
        <view class="goods-info">
          <text class="goods-title-sm">{{item.title}}</text>
          <view class="meta-row">
            <text class="text-2xs text-price font-semibold">¥{{item.price}}</text>
            <view class="status-tag status-{{item.status}}">
              {{item.status === 'ON_SALE' ? '在售' : item.status === 'OFF_SHELF' ? '已下架' : item.status === 'PENDING_REVIEW' ? '审核中' : '已驳回'}}
            </view>
          </view>
          <text wx:if="{{item.status === 'REJECTED' && item.auditRemark}}" class="reject-reason">原因：{{item.auditRemark}}</text>
        </view>
        <view class="actions-row">
          <view class="btn btn-sm btn-secondary" bindtap="editGoods" data-id="{{item.id}}">编辑</view>
          <view wx:if="{{item.status === 'ON_SALE' || item.status === 'OFF_SHELF'}}" class="btn btn-sm" bindtap="toggleStatus" data-id="{{item.id}}" data-status="{{item.status}}">
            {{item.status === 'ON_SALE' ? '下架' : '上架'}}
          </view>
          <view class="btn btn-sm btn-danger" bindtap="removeGoods" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </block>

    <view wx:if="{{loadingMore}}" class="loading-more">
      <text>正在加载更多...</text>
    </view>
    <view wx:elif="{{!hasMore && goodsItems.length > 0}}" class="loading-more">
      <text>已经到底了</text>
    </view>
  </view>

  <view class="card settings-card">
    <view class="settings-item" bindtap="openAccountBindModal">
      <view class="settings-left">
        <text class="settings-icon settings-icon-account">@</text>
        <text class="settings-label">绑定账号</text>
      </view>
      <text class="settings-arrow">›</text>
    </view>
    <view class="settings-item" bindtap="showFeedback">
      <view class="settings-left">
        <text class="settings-icon settings-icon-feedback">?</text>
        <text class="settings-label">意见反馈</text>
      </view>
      <text class="settings-arrow">›</text>
    </view>
  </view>

  <button class="btn btn-ghost btn-full" bindtap="logout">退出登录</button>

  <view class="modal-mask" wx:if="{{showProfileModal}}" bindtap="closeProfileEditor"></view>
  <view class="modal-dialog profile-modal" wx:if="{{showProfileModal}}">
    <view class="modal-title">编辑资料</view>
    <view class="modal-body profile-modal-body">
      <view class="profile-modal-avatar">
        <view class="avatar-btn profile-modal-avatar-btn" bindtap="chooseAvatar">
          <image wx:if="{{draftAvatarUrl}}" src="{{draftAvatarUrl}}" mode="aspectFill" />
          <text wx:else>{{profileDraft.nickname[0] || '我'}}</text>
        </view>
        <text class="helper-text">点击更换头像，保存后生效</text>
      </view>

      <view class="nick-section">
        <text class="form-label">专业昵称</text>
        <view class="input-field flex items-center">
          <input value="{{profileDraft.nickname}}" class="input-field-nick" placeholder="如：软工-231" maxlength="64" bindinput="onNicknameInput" />
        </view>
        <text class="field-hint">建议填写专业-班级，便于校内交易身份识别</text>
      </view>

      <view class="nick-section">
        <text class="form-label">微信号</text>
        <view class="input-field flex items-center">
          <input value="{{profileDraft.wechatId}}" class="input-field-nick" placeholder="填写后便于同学联系" maxlength="64" bindinput="onWechatIdInput" />
        </view>
      </view>

      <view class="nick-section">
        <text class="form-label">QQ号</text>
        <view class="input-field flex items-center">
          <input value="{{profileDraft.qq}}" class="input-field-nick" type="number" placeholder="填写后便于同学联系" maxlength="12" bindinput="onQqInput" />
        </view>
        <view wx:if="{{qqPreviewAvatarUrl}}" class="qq-preview-row">
          <image class="qq-preview-avatar" src="{{qqPreviewAvatarUrl}}" mode="aspectFill" />
          <view class="qq-preview-copy">
            <text class="qq-preview-title">QQ头像预览</text>
            <text class="qq-preview-desc">保存资料后，未上传头像时将使用它</text>
          </view>
        </view>
        <text class="field-hint">微信号和QQ号用于校内交易联系，未填写将无法联系到你</text>
      </view>

      <text wx:if="{{info}}" class="block mt-16 text-center text-2xs status-text-error">{{info}}</text>
    </view>
    <view class="modal-footer profile-modal-footer">
      <button class="btn btn-ghost profile-modal-cancel" disabled="{{saving}}" bindtap="closeProfileEditor">取消</button>
      <button class="btn btn-primary profile-modal-save" loading="{{saving}}" disabled="{{saving}}" bindtap="saveProfile">
        {{saving ? '保存中...' : '保存资料'}}
      </button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showAccountBindModal}}" bindtap="closeAccountBindModal"></view>
  <view class="modal-dialog account-bind-modal" wx:if="{{showAccountBindModal}}">
    <view class="modal-title">绑定账号</view>
    <view class="modal-body account-bind-body">
      <view class="account-bind-section">
        <view class="wechat-bind-row">
          <view class="wechat-bind-copy">
            <text class="wechat-bind-title">微信快捷登录</text>
            <text wx:if="{{profile.wechatOpenid}}" class="wechat-bind-desc">微信快捷登录已绑定</text>
            <text wx:else class="wechat-bind-desc">绑定后可用微信直接进入当前账号</text>
          </view>
          <button wx:if="{{!profile.wechatOpenid}}" class="btn btn-secondary btn-sm wechat-bind-button" loading="{{bindingWechat}}" disabled="{{bindingWechat}}" bindtap="bindWechat">
            {{bindingWechat ? '绑定中...' : '绑定微信'}}
          </button>
          <text wx:else class="wechat-bind-status">已绑定</text>
        </view>
      </view>

      <view class="account-bind-section">
        <view class="account-bind-head">
          <text class="wechat-bind-title">QQ邮箱账号</text>
          <text wx:if="{{profile.email}}" class="wechat-bind-status">已绑定</text>
        </view>
        <text wx:if="{{profile.email}}" class="wechat-bind-desc">{{profile.email}} 可用于邮箱密码登录</text>
        <block wx:else>
          <view class="contact-modal-field">
            <text class="form-label">QQ邮箱</text>
            <view class="inline-row">
              <input class="input-field" type="text" placeholder="xxx@qq.com" value="{{bindEmailForm.email}}" bindinput="onBindEmailInput" />
              <button class="btn btn-secondary btn-sm email-code-button" loading="{{sendingBindEmailCode}}" disabled="{{sendingBindEmailCode || bindingEmail}}" bindtap="sendBindEmailCode">
                {{sendingBindEmailCode ? '发送中' : '验证码'}}
              </button>
            </view>
          </view>
          <view class="contact-modal-field">
            <text class="form-label">验证码</text>
            <input class="input-field" type="number" maxlength="6" placeholder="6位验证码" value="{{bindEmailForm.code}}" bindinput="onBindEmailCodeInput" />
          </view>
          <view class="contact-modal-field">
            <text class="form-label">登录密码</text>
            <input class="input-field" password placeholder="至少6位，绑定后可邮箱登录" value="{{bindEmailForm.password}}" bindinput="onBindEmailPasswordInput" />
          </view>
          <button class="btn btn-primary btn-full account-bind-action" loading="{{bindingEmail}}" disabled="{{bindingEmail || sendingBindEmailCode}}" bindtap="bindEmail">
            {{bindingEmail ? '绑定中...' : '绑定QQ邮箱'}}
          </button>
        </block>
      </view>

      <text wx:if="{{accountBindMessage}}" class="block mt-16 text-center text-2xs status-text-error">{{accountBindMessage}}</text>
      <view wx:if="{{accountMergeHint}}" class="merge-risk-box">
        <text class="notice-title">账号合并需谨慎</text>
        <text class="notice-item">该邮箱已有账号，暂不自动合并。合并会涉及商品、头像、联系方式和登录身份迁移，需要确认归属后再处理。</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-primary btn-full" disabled="{{bindingWechat || sendingBindEmailCode || bindingEmail}}" bindtap="closeAccountBindModal">知道了</button>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showFeedbackModal}}" bindtap="closeFeedback"></view>
  <view class="modal-dialog" wx:if="{{showFeedbackModal}}">
    <view class="modal-title">意见反馈</view>
    <view class="modal-body">
      <text class="modal-text">这是由学生独立开发的校园二手信息平台，欢迎反馈问题和建议。</text>
      <text class="modal-text">反馈 QQ 群：</text>
      <view class="modal-qq-row">
        <text class="modal-qq-number">1078739008</text>
        <text class="btn-copy" bindtap="copyQQ">复制</text>
      </view>
      <view class="notice-box">
        <text class="notice-title">注意事项</text>
        <text class="notice-item">1. 发布内容需要审核，通过后才会展示。</text>
        <text class="notice-item">2. 低质或无效内容可能被删除，可通过反馈群联系管理员。</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-primary btn-full" bindtap="closeFeedback">知道了</button>
    </view>
  </view>
</view>
