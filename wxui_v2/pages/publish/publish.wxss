/* ===== Top Bar ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

/* ===== Photo Grid ===== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: calc(33.33% - 12rpx);
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-item::before {
  content: '';
  display: block;
  padding-bottom: 100%;
}

.photo-item image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.photo-add {
  position: relative;
  width: calc(33.33% - 12rpx);
  border: 4rpx dashed #ddd;
  border-radius: 16rpx;
  background-color: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add::before {
  content: '';
  display: block;
  padding-bottom: 100%;
}

.del-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.cover-label {
  position: absolute;
  bottom: 0;
  left: 0;
  background-color: #ff6b3d;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 12rpx 0 0;
}

/* ===== Category / Condition Pickers ===== */
.picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 24rpx 0;
}

.picker-item {
  padding: 20rpx 16rpx;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  background-color: #fff;
  font-size: 26rpx;
  color: #666;
  width: calc(33.33% - 12rpx);
  text-align: center;
}

.picker-item-active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
}

/* ===== Location Chips ===== */
.chip {
  padding: 16rpx 32rpx;
  border: 2rpx solid #eee;
  border-radius: 40rpx;
  background-color: #fff;
  font-size: 26rpx;
  color: #666;
}

.chip-active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
}

/* ===== Character Count ===== */
.char-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.char-count-full {
  color: #ff4444;
  font-weight: 600;
}

/* ===== Bottom Bar ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(255,255,255,0.95);
  border-top: 2rpx solid #f0f0f0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  z-index: 20;
}
