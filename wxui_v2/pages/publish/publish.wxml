<view class="page-shell-plain publish-shell">
  <view class="top-bar">
    <view>
      <text class="page-title">{{goodsId ? '编辑闲置' : '发布闲置'}}</text>
      <text class="helper-text mt-8">内容审核通过后会展示给同校同学</text>
    </view>
    <view class="status-tag status-PENDING_REVIEW">审核后展示</view>
  </view>

  <view wx:if="{{loading}}" class="loading-text">正在加载商品信息...</view>

  <view class="p-28 flex flex-col gap-20">
    <!-- 第一步：选择分类 -->
    <view class="card p-28">
      <view class="card-head">
        <text class="section-title">选择商品分类</text>
        <text wx:if="{{errors.categoryId}}" class="field-error">{{errors.categoryId}}</text>
      </view>
      <view class="picker-grid">
        <view wx:for="{{categories}}" wx:key="id" class="picker-item {{form.categoryId == item.id ? 'picker-item-active' : ''}}" data-id="{{item.id}}" bindtap="chooseCategory">
          {{item.name}}
        </view>
      </view>
    </view>

    <!-- 第二步：选了分类后才显示其余内容 -->
    <block wx:if="{{form.categoryId}}">
      <view class="card p-28">
        <view class="card-head">
          <text class="section-title">商品图片</text>
          <text class="helper-text">{{form.photos.length}}/9</text>
        </view>
        <view class="photo-grid {{errors.photos ? 'photo-grid-error' : ''}}">
          <view class="photo-item" wx:for="{{form.photos}}" wx:key="url">
            <image src="{{item.url}}" mode="aspectFill" />
            <view class="del-btn" data-index="{{index}}" bindtap="removePhoto">×</view>
            <view wx:if="{{index === 0}}" class="cover-label">封面</view>
          </view>
          <view wx:if="{{form.photos.length < 9}}" class="photo-add" bindtap="chooseImages">
            <text>+</text>
          </view>
        </view>
        <text wx:if="{{errors.photos}}" class="field-error">{{errors.photos}}</text>
        <text wx:else class="field-hint">首图会作为商品封面，建议上传清晰实拍图。</text>
      </view>

      <view class="card px-32">
        <view class="field-row">
          <text class="text-sm flex-shrink-0 text-text-secondary">价格</text>
          <view class="flex items-center flex-1">
            <text class="text-2xl font-bold mr-8 text-price">¥</text>
            <input class="input-field-price" type="digit" placeholder="0.00" value="{{form.price}}" bindinput="onPriceInput" />
          </view>
        </view>
        <text wx:if="{{errors.price}}" class="field-error pb-16">{{errors.price}}</text>

        <view class="field-row">
          <text class="text-sm flex-shrink-0 text-text-secondary">标题</text>
          <input class="input-field-text" type="text" placeholder="例如：考研英语真题" value="{{form.title}}" maxlength="20" bindinput="onTitleInput" />
          <text class="char-count {{form.title.length >= 20 ? 'char-count-full' : ''}}">{{form.title.length}}/20</text>
        </view>
        <text wx:if="{{errors.title}}" class="field-error pb-16">{{errors.title}}</text>

        <view class="field-row">
          <text class="text-sm flex-shrink-0 text-text-secondary">描述</text>
          <input class="input-field-text" type="text" placeholder="补充成色、配件、取货说明" value="{{form.description}}" maxlength="80" bindinput="onDescriptionInput" />
          <text class="char-count {{form.description.length >= 80 ? 'char-count-full' : ''}}">{{form.description.length}}/80</text>
        </view>
        <text wx:if="{{errors.description}}" class="field-error pb-16">{{errors.description}}</text>
      </view>

      <view class="card p-28">
        <text class="section-title">成色</text>
        <view class="picker-grid">
          <view wx:for="{{conditionOptions}}" wx:key="*this" class="picker-item {{form.conditionLevel === item ? 'picker-item-active' : ''}}" data-value="{{item}}" bindtap="chooseCondition">
            {{item}}
          </view>
        </view>
      </view>

      <view class="card p-28">
        <text class="section-title">交易地点</text>
        <view class="flex flex-wrap gap-16 py-24">
          <view wx:for="{{locationOptions}}" wx:key="*this" class="chip {{form.campusLocation === item ? 'chip-active' : ''}}" data-value="{{item}}" bindtap="chooseLocation">
            {{item}}
          </view>
        </view>
      </view>
    </block>
  </view>

  <view class="bottom-bar" wx:if="{{form.categoryId}}">
    <text class="block mb-16 text-2xs text-center {{info ? 'status-text-error' : 'status-text'}}">{{info || '提交后会进入审核队列'}}</text>
    <button class="btn btn-primary btn-full" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">
      {{submitting ? '提交中...' : goodsId ? '保存修改' : '发布闲置'}}
    </button>
  </view>
</view>
