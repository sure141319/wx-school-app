<view class="flex flex-col gap-28 p-28 pb-120">
  <view class="card p-28" style="background:linear-gradient(150deg,#fff7e6 0%,#f8f3ea 45%,#edf5ff 100%)">
    <view class="flex items-center gap-20">
      <view class="search-bar">
        <text style="color:#8894a6;font-size:32rpx;margin-right:16rpx">⌕</text>
        <input placeholder="搜索你想买的闲置" bindinput="onSearchInput" bindconfirm="onSearch" />
      </view>
      <view class="flex gap-12">
        <view class="icon-btn" bindtap="loadGoods">
          <text style="font-size:36rpx;line-height:1">↻</text>
        </view>
      </view>
    </view>
    <text class="block mt-28 mb-8 text-3xl tracking-tight">校园闲置集市</text>
    <text class="block text-xs text-secondary">发现同校在售物品，面对面更安心</text>
  </view>

  <scroll-view class="flex whitespace-nowrap" scroll-x enable-flex>
    <view
      wx:for="{{categoryItems}}"
      wx:key="id"
      class="cat-pill {{categoryId === item.id ? 'cat-pill-active' : ''}}"
      bindtap="chooseCategory"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <text wx:if="{{statusText}}" class="status-line">{{statusText}}</text>

  <view wx:if="{{loading}}" class="loading-text">
    <text>正在加载商品...</text>
  </view>

  <view wx:elif="{{goodsItems.length}}" class="flex gap-24">
    <view class="flex-1 flex flex-col">
      <view wx:for="{{leftGoods}}" wx:key="id">
        <view class="goods-card" bindtap="openGoods" data-id="{{item.id}}">
          <view class="cover-wrap">
            <image wx:if="{{item.imageUrls.length}}" class="cover-img" src="{{item.imageUrls[0]}}" mode="aspectFill" lazy-load />
            <view wx:else class="cover-empty">暂无图片</view>
            <view class="price-tag">¥{{item.price}}</view>
            <view class="cond-tag">{{item.conditionLevel || '成色未知'}}</view>
          </view>
          <view class="card-meta">
            <text class="card-title">{{item.title}}</text>
            <text class="card-sub">{{item.campusLocation || '校内交易'}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="flex-1 flex flex-col">
      <view wx:for="{{rightGoods}}" wx:key="id">
        <view class="goods-card" bindtap="openGoods" data-id="{{item.id}}">
          <view class="cover-wrap">
            <image wx:if="{{item.imageUrls.length}}" class="cover-img" src="{{item.imageUrls[0]}}" mode="aspectFill" lazy-load />
            <view wx:else class="cover-empty">暂无图片</view>
            <view class="price-tag">¥{{item.price}}</view>
            <view class="cond-tag">{{item.conditionLevel || '成色未知'}}</view>
          </view>
          <view class="card-meta">
            <text class="card-title">{{item.title}}</text>
            <text class="card-sub">{{item.campusLocation || '校内交易'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="card p-40 text-center">
    <text class="block text-lg mb-16">暂时没有匹配的商品</text>
    <text class="block text-xs" style="color:#7f8b9f">换个关键词或分类试试</text>
  </view>

  <view wx:if="{{loadingMore}}" class="loading-more">
    <text>正在加载更多...</text>
  </view>
  <view wx:elif="{{!hasMore && goodsItems.length > 0}}" class="loading-more">
    <text>没有更多了</text>
  </view>
</view>
