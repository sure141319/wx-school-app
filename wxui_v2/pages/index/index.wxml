<view class="page-shell flex flex-col gap-28">
  <view class="home-hero">
    <view class="flex items-center gap-16">
      <view class="search-bar">
        <text class="search-icon">⌕</text>
        <input placeholder="搜索你想买的闲置" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
      </view>
      <view class="icon-btn" bindtap="loadGoods" aria-label="刷新">↻</view>
    </view>

    <view class="mt-28">
      <text class="eyebrow">Campus Trade</text>
      <text class="display-title mt-8">校园闲置集市</text>
      <text class="helper-text mt-12">发现同校好物，约在校内交易。</text>
    </view>

    <view class="hero-footer">
      <view class="trust-badge">
        <view class="trust-dot"></view>
        <text class="helper-text">认证同学发布，图片审核后展示</text>
      </view>
      <view class="btn btn-secondary btn-sm" bindtap="goToPublish">去发布</view>
    </view>
  </view>

  <scroll-view class="flex whitespace-nowrap" scroll-x enable-flex>
    <view
      wx:for="{{categoryItems}}"
      wx:key="id"
      class="cat-pill {{categoryId === item.id ? 'cat-pill-active' : ''}}"
      bindtap="chooseCategory"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <text wx:if="{{statusText}}" class="status-line">{{statusText}}</text>

  <view wx:if="{{loading}}" class="loading-text">
    <text>正在加载商品...</text>
  </view>

  <view wx:elif="{{goodsItems.length}}" class="flex gap-24">
    <view class="flex-1 flex flex-col">
      <view wx:for="{{leftGoods}}" wx:key="id">
        <view class="goods-card" bindtap="openGoods" data-id="{{item.id}}">
          <view class="cover-wrap">
            <image wx:if="{{item.imageUrls.length}}" class="cover-img" src="{{item.imageUrls[0]}}" mode="aspectFill" lazy-load />
            <view wx:else class="cover-empty">暂无图片</view>
            <view class="price-tag">¥{{item.price}}</view>
            <view class="cond-tag">{{item.conditionLevel || '成色未知'}}</view>
          </view>
          <view class="card-meta">
            <text class="card-title">{{item.title}}</text>
            <text class="card-sub">{{item.campusLocation || '校内交易'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="flex-1 flex flex-col">
      <view wx:for="{{rightGoods}}" wx:key="id">
        <view class="goods-card" bindtap="openGoods" data-id="{{item.id}}">
          <view class="cover-wrap">
            <image wx:if="{{item.imageUrls.length}}" class="cover-img" src="{{item.imageUrls[0]}}" mode="aspectFill" lazy-load />
            <view wx:else class="cover-empty">暂无图片</view>
            <view class="price-tag">¥{{item.price}}</view>
            <view class="cond-tag">{{item.conditionLevel || '成色未知'}}</view>
          </view>
          <view class="card-meta">
            <text class="card-title">{{item.title}}</text>
            <text class="card-sub">{{item.campusLocation || '校内交易'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="card p-40 text-center">
    <view class="empty-list">
      <view class="empty-icon-sm">⌕</view>
      <text class="empty-title">还没有匹配的商品</text>
      <text class="empty-desc">换个关键词或分类试试，也可以发布你的第一件闲置。</text>
      <view class="btn btn-primary btn-sm mt-16" bindtap="goToPublish">发布闲置</view>
    </view>
  </view>

  <view wx:if="{{loadingMore}}" class="loading-more">
    <text>正在加载更多...</text>
  </view>
  <view wx:elif="{{!hasMore && goodsItems.length > 0}}" class="loading-more">
    <text>已经到底了</text>
  </view>
</view>
