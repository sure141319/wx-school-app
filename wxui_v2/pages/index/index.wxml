<view class="page-shell market-shell">
  <view class="home-hero">
    <view class="market-stamp" aria-hidden="true">
      <text class="market-stamp-cn">循环</text>
      <text class="market-stamp-en">校内闲置</text>
    </view>

    <view class="home-hero-copy">
      <text class="home-kicker">同校流转 · 当面交易</text>
      <text class="home-title">闲置在身边</text>
      <text class="home-hero-subtitle">让闲置在校园里找到下一位主人。</text>
    </view>

    <view class="hero-footer">
      <view class="trust-badge">
        <view class="trust-dot"></view>
        <text class="hero-note">图片审核后展示</text>
      </view>
      <button class="hero-publish-btn" bindtap="goToPublish">发布闲置</button>
    </view>
  </view>

  <view class="home-search-section">
    <view class="search-bar home-search-bar">
      <view class="search-mark" aria-hidden="true">
        <view class="search-mark-handle"></view>
      </view>
      <input placeholder="搜课本、四六级耳机..." value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
      <button class="search-action" bindtap="onSearch">搜索</button>
    </view>
  </view>

  <scroll-view class="category-strip" scroll-x enable-flex show-scrollbar="{{false}}">
    <view
      wx:for="{{categoryItems}}"
      wx:key="id"
      class="cat-pill {{categoryId === item.id ? 'cat-pill-active' : ''}}"
      bindtap="chooseCategory"
      data-id="{{item.id}}"
    >
      <text>{{item.name}}</text>
    </view>
  </scroll-view>

  <view class="goods-section-head">
    <view class="goods-section-title">
      <text class="goods-section-kicker">同校新上架</text>
      <text class="goods-section-name">刚刚上架</text>
    </view>
    <text wx:if="{{goodsItems.length}}" class="goods-count">{{goodsItems.length}} 件可逛</text>
  </view>

  <text wx:if="{{statusText}}" class="status-line">{{statusText}}</text>

  <view wx:if="{{loading}}" class="loading-text">
    <text>正在寻找同校好物...</text>
  </view>

  <view wx:elif="{{goodsItems.length}}" class="goods-grid">
    <view wx:for="{{goodsItems}}" wx:key="id" class="goods-grid-item">
      <view class="goods-card" bindtap="openGoods" data-id="{{item.id}}">
        <view class="cover-wrap">
          <image wx:if="{{item.coverImageUrl}}" class="cover-img" src="{{item.coverImageUrl}}" mode="aspectFill" lazy-load />
          <view wx:else class="cover-empty">暂无图片</view>
          <view class="cond-tag">{{item.conditionLevel || '成色未知'}}</view>
        </view>
        <view class="card-meta">
          <text class="card-title">{{item.title}}</text>
          <view class="card-info-row">
            <view class="card-price"><text class="card-price-symbol">¥</text>{{item.price}}</view>
            <text class="card-location">{{item.campusLocation || '校内交易'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="home-empty">
    <view class="empty-search-mark" aria-hidden="true"></view>
    <text class="empty-title">这一栏暂时空着</text>
    <text class="empty-desc">换个关键词或分类，也可以发布你的第一件闲置。</text>
    <button class="btn btn-primary btn-sm mt-16" bindtap="goToPublish">发布闲置</button>
  </view>

  <view wx:if="{{loadingMore}}" class="loading-more">
    <text>正在加载更多...</text>
  </view>
  <view wx:elif="{{!hasMore && goodsItems.length > 0}}" class="loading-more">
    <text>逛到底了，晚点再来看看</text>
  </view>
</view>
