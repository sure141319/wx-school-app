/* ===== Search ===== */
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  border: 2rpx solid #dde4ef;
  border-radius: 24rpx;
  background-color: rgba(255,255,255,0.9);
  padding: 0 24rpx;
  height: 84rpx;
}

.search-bar input {
  flex: 1;
  font-size: 28rpx;
  height: 100%;
}

/* ===== Category Pills ===== */
.cat-pill {
  display: inline-flex;
  align-items: center;
  border: 2rpx solid #dde4ef;
  border-radius: 999rpx;
  height: 68rpx;
  padding: 0 28rpx;
  background-color: rgba(255,255,255,0.8);
  color: #5e6d83;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.cat-pill-active {
  background-color: #1e5ea6;
  border-color: #1e5ea6;
  color: #fff;
  font-weight: 600;
}

/* ===== Goods Card ===== */
.goods-card {
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background-color: #fff;
  border: 2rpx solid #ece7de;
  box-shadow: 0 16rpx 32rpx rgba(26,34,51,0.06);
}

.card-meta {
  padding: 20rpx 20rpx 24rpx;
}

.card-title {
  font-size: 28rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.card-sub {
  margin-top: 8rpx;
  color: #7d889a;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}
