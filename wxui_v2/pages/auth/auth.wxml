<view class="auth-shell">
  <view class="flex justify-between items-center">
    <view class="auth-head-btn" bindtap="goBack">
      <text>‹ 返回</text>
    </view>
    <view class="auth-head-btn" bindtap="switchMode" wx:if="{{mode !== 'reset'}}">
      <text>{{mode === 'login' ? '去注册' : '去登录'}}</text>
    </view>
    <view class="auth-head-btn" bindtap="goToLogin" wx:else>
      <text>去登录</text>
    </view>
  </view>

  <view class="mt-48 text-center">
    <text class="auth-eyebrow">校园闲置平台</text>
    <text class="display-title mt-16 mb-16">
      {{mode === 'login' ? '欢迎回来' : mode === 'register' ? '创建账号' : '重置密码'}}
    </text>
    <text class="helper-text">仅支持 QQ 邮箱注册，用于校内交易联系。</text>
  </view>

  <block wx:if="{{mode === 'login'}}">
    <view class="auth-form">
      <view class="form-row relative">
        <text class="form-label">QQ 邮箱</text>
        <input class="input-field" value="{{loginForm.email}}" placeholder="请输入 xxx@qq.com" bindinput="onLoginEmailInput" bindfocus="showEmailHistory" bindblur="hideEmailHistory" />
        <view wx:if="{{showEmailHistory && savedEmails.length}}" class="email-history">
          <view class="email-history-header">
            <text class="text-2xs text-text-muted">最近使用</text>
          </view>
          <view wx:for="{{savedEmails}}" wx:key="*this" class="email-history-item" catchtap="selectSavedEmail" data-email="{{item}}">
            <text class="text-base flex-1 text-text-main">{{item}}</text>
            <text class="text-2xs text-text-soft">›</text>
          </view>
        </view>
        <text wx:if="{{loginForm.email && !loginEmailValid}}" class="field-error">请输入正确的 QQ 邮箱格式</text>
      </view>
      <view class="form-row">
        <text class="form-label">密码</text>
        <input class="input-field" value="{{loginForm.password}}" password placeholder="请输入密码" bindinput="onLoginPasswordInput" />
        <text wx:if="{{loginForm.password && !loginPasswordValid}}" class="field-error">密码至少 6 位</text>
      </view>
      <button class="btn btn-primary btn-full" disabled="{{loading || !isLoginFormValid}}" loading="{{loading}}" bindtap="handleLogin">
        {{loading ? '登录中...' : '登录'}}
      </button>
      <view class="text-link" bindtap="goToReset">
        <text>忘记密码？</text>
      </view>
    </view>
  </block>

  <block wx:elif="{{mode === 'register'}}">
    <view class="auth-form">
      <view class="form-row">
        <text class="form-label">QQ 邮箱</text>
        <view class="inline-row">
          <input class="input-field" value="{{registerForm.email}}" placeholder="请输入 xxx@qq.com" bindinput="onRegisterEmailInput" />
          <button class="send-code-btn" disabled="{{sendCodeCooldown > 0 || sendingCode || !registerEmailValid || !registerForm.email}}" bindtap="handleSendCode" data-purpose="REGISTER" data-type="register">
            {{sendCodeCooldown > 0 ? sendCodeCooldown + 's' : '验证码'}}
          </button>
        </view>
        <text wx:if="{{registerForm.email && !registerEmailValid}}" class="field-error">请输入正确的 QQ 邮箱格式</text>
        <text wx:if="{{registerEmailValid && registerForm.email}}" class="field-hint">验证码将发送到该邮箱。</text>
      </view>
      <view class="form-row">
        <text class="form-label">验证码</text>
        <input class="input-field" value="{{registerForm.code}}" type="number" maxlength="6" placeholder="请输入 6 位验证码" bindinput="onRegisterCodeInput" />
        <text wx:if="{{registerForm.code && !registerCodeValid}}" class="field-error">验证码为 6 位数字</text>
      </view>
      <view class="form-row">
        <text class="form-label">昵称</text>
        <input class="input-field" value="{{registerForm.nickname}}" placeholder="给自己起个昵称" bindinput="onRegisterNicknameInput" maxlength="20" />
        <text wx:if="{{registerForm.nickname && !registerNicknameValid}}" class="field-error">昵称需要 2-20 个字符</text>
      </view>
      <view class="form-row">
        <text class="form-label">密码</text>
        <input class="input-field" value="{{registerForm.password}}" password placeholder="至少 6 位" bindinput="onRegisterPasswordInput" />
        <text wx:if="{{registerForm.password && !registerPasswordValid}}" class="field-error">密码至少 6 位</text>
      </view>
      <button class="btn btn-primary btn-full" disabled="{{loading || !isRegisterFormValid}}" loading="{{loading}}" bindtap="handleRegister">
        {{loading ? '提交中...' : '完成注册'}}
      </button>
      <view class="text-link" bindtap="switchMode">
        <text>已有账号，去登录</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="auth-form">
      <view class="form-row">
        <text class="form-label">QQ 邮箱</text>
        <view class="inline-row">
          <input class="input-field" value="{{resetForm.email}}" placeholder="请输入注册时的 QQ 邮箱" bindinput="onResetEmailInput" />
          <button class="send-code-btn" disabled="{{resetCodeCooldown > 0 || sendingCode || !resetEmailValid || !resetForm.email}}" bindtap="handleSendCode" data-purpose="RESET_PASSWORD" data-type="reset">
            {{resetCodeCooldown > 0 ? resetCodeCooldown + 's' : '验证码'}}
          </button>
        </view>
        <text wx:if="{{resetForm.email && !resetEmailValid}}" class="field-error">请输入正确的 QQ 邮箱格式</text>
      </view>
      <view class="form-row">
        <text class="form-label">验证码</text>
        <input class="input-field" value="{{resetForm.code}}" type="number" maxlength="6" placeholder="请输入 6 位验证码" bindinput="onResetCodeInput" />
        <text wx:if="{{resetForm.code && !resetCodeValid}}" class="field-error">验证码为 6 位数字</text>
      </view>
      <view class="form-row">
        <text class="form-label">新密码</text>
        <input class="input-field" value="{{resetForm.newPassword}}" password placeholder="至少 6 位" bindinput="onResetPasswordInput" />
        <text wx:if="{{resetForm.newPassword && !resetPasswordValid}}" class="field-error">密码至少 6 位</text>
      </view>
      <view class="form-row">
        <text class="form-label">确认密码</text>
        <input class="input-field" value="{{resetForm.confirmPassword}}" password placeholder="再次输入新密码" bindinput="onResetConfirmPasswordInput" />
        <text wx:if="{{resetForm.confirmPassword && !resetConfirmPasswordValid}}" class="field-error">两次输入的密码不一致</text>
      </view>
      <button class="btn btn-primary btn-full" disabled="{{loading || !isResetFormValid}}" loading="{{loading}}" bindtap="handleReset">
        {{loading ? '提交中...' : '重置密码'}}
      </button>
      <view class="text-link" bindtap="goToLogin">
        <text>返回登录</text>
      </view>
    </view>
  </block>

  <text class="block mt-28 text-center text-xs message-slot {{message ? 'status-text-error' : 'status-text'}}">{{message || ' '}}</text>

  <view class="flex justify-center mt-48 pb-32">
    <text class="text-xs underline text-primary" bindtap="showFeedback">意见反馈</text>
  </view>

  <view class="modal-mask" wx:if="{{showFeedbackModal}}" bindtap="closeFeedback"></view>
  <view class="modal-dialog" wx:if="{{showFeedbackModal}}">
    <view class="modal-title">意见反馈</view>
    <view class="modal-body">
      <text class="modal-text">这是由学生独立开发的校园二手信息平台，欢迎反馈问题和建议。</text>
      <text class="modal-text">反馈 QQ 群：</text>
      <view class="modal-qq-row">
        <text class="modal-qq-number">1078739008</text>
        <text class="btn-copy" bindtap="copyQQ">复制</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn btn-primary btn-full" bindtap="closeFeedback">知道了</button>
    </view>
  </view>
</view>
